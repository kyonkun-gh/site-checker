# 監控設定
# 排程設定（check_interval_hours 與 check_times 只能擇一）
check_interval_hours: 1
# check_times:
#   - "12:00"
#   - "18:00"

network:
  timeout_seconds: 10
  retry:
    enabled: true
    max_retries: 2
    backoff_strategy: exponential
    initial_delay_seconds: 0.5
    multiplier: 2.0
    max_delay_seconds: 5.0
    jitter_seconds: 0.25

# 監控目標
sites:
  - url: "https://your.website.com"
    expected_status: "good"
    ocsp_url: "http://ocsp.website.com"
    issuer_url: ""  # 選填：指定 OCSP issuer 憑證 URL；留空則使用憑證內建 AIA

  - url: "https://your.website2.com"
    expected_status: "expired"
    ocsp_url: "http://ocsp.website2.com"
    
  - url: "https://your.website3.com"
    expected_status: "revoked"
    ocsp_url: "http://ocsp.website3.com"